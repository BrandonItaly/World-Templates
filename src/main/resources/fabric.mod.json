{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "contributors": [
    "${mod_credits}"
  ],
  "contact": {
    "homepage": "${mod_homepage}",
    "sources": "${mod_source}",
    "issues": "${mod_issues}"
  },
  "license": "${mod_license}",
  "icon": "assets/worldtemplates/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.brandonitaly.worldtemplates.WorldTemplates"
    ],
    "client": [
      "com.brandonitaly.worldtemplates.client.WorldTemplatesClient"
    ]
  },
  "accessWidener": "${aw}",
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabric-api": "*",
    "fabricloader": ">=0.17",
    "minecraft": ["${mc_version_range}"]
  }
}
